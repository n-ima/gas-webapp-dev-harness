{
  "permissions": {
    "deny": [
      "Edit(.github/agents/**)",
      "Write(.github/agents/**)",
      "Edit(.github/hooks/**)",
      "Write(.github/hooks/**)",
      "Edit(.github/workflows/**)",
      "Write(.github/workflows/**)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Edit(.claude/agents/**)",
      "Write(.claude/agents/**)",
      "Edit(.claude/commands/**)",
      "Write(.claude/commands/**)",
      "Edit(.agents/workflows/**)",
      "Write(.agents/workflows/**)",
      "Edit(AGENTS.md)",
      "Write(AGENTS.md)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Edit(plugin.json)",
      "Write(plugin.json)",
      "Edit(.vscode/settings.json)",
      "Write(.vscode/settings.json)",
      "Edit(docs/**/*_template.md)",
      "Write(docs/**/*_template.md)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .github/hooks/scripts/guard-template-edit.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .github/hooks/scripts/guard-harness-config-edit.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .github/hooks/scripts/guard-secret-leak.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .github/hooks/scripts/guard-dangerous-git.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .github/hooks/scripts/guard-secret-leak.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .github/hooks/scripts/warn-stale-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .github/hooks/scripts/inject-progress.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
